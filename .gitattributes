* text=auto

# Keep source and config files normalized to LF across platforms.
*.py text eol=lf
*.js text eol=lf
*.css text eol=lf
*.html text eol=lf
*.json text eol=lf
*.md text eol=lf
*.toml text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.txt text eol=lf

# Windows-native scripts.
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf
